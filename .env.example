# ==========================================
# === Neuro Notes API Configuration ===
# ==========================================
ASPNETCORE_ENVIRONMENT=Development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
API_PORT_EXTERNAL=5000
API_PORT_INTERNAL=8080

CLIENT_PORT=3000

# ==========================================
# === PostgreSQL Configuration ===
# ==========================================
POSTGRES_DB=neuro-notes-postgres
POSTGRES_USER=postgres-user
POSTGRES_PASSWORD=postgres-password
POSTGRES_PORT=5432

# ==========================================
# === MinIO Configuration ===
# ==========================================
MINIO_HOST=minio
MINIO_PUBLIC_HOST=localhost
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minio-user
MINIO_ROOT_PASSWORD=minio-password
MINIO_WITH_SSL=false
MINIO_PRIVATE_BUCKET_NAME=neuro-notes-minio-private
MINIO_PUBLIC_BUCKET_NAME=neuro-notes-minio-public

# ==========================================
# === JWT Configuration ===
# ==========================================
JWT_ISSUER=neuro-notes-api
JWT_AUDIENCE=neuro-notes-web-client

JWT_ACCESS_SECRET=SUPER_SECRET_KEY_FOR_ACCESS_TOKENS_MUST_BE_VERY_LONG_AND_SECURE
JWT_ACCESS_EXPIRY_MINUTES=15

JWT_REFRESH_SECRET=ANOTHER_SECRET_KEY_FOR_REFRESH_TOKENS_IF_NEEDED_ALSO_LONG
JWT_REFRESH_EXPIRY_DAYS=7

# ==========================================
# === App Configuration ===
# ==========================================
APP_DEFAULT_INTERFACE_LANGUAGE=ru
APP_DEFAULT_NICKNAME=user
APP_DEFAULT_THEME=system

# ==========================================
# === AI Configuration ===
# ==========================================
AI_DEFAULT_OPERATION_LANGUAGE=ru
AI_DEFAULT_TRANSCRIPTION_PROVIDER=VoskLocal
AI_DEFAULT_GLOBAL_CHAT_PROVIDER=OllamaLocal
AI_DEFAULT_NOTE_CHAT_PROVIDER=OllamaLocal
AI_DEFAULT_STRUCTURE_PROVIDER=OllamaLocal
AI_DEFAULT_SUMMARY_PROVIDER=OllamaLocal
AI_DEFAULT_GLOBAL_CHAT_TEMPERATURE=0.7
AI_DEFAULT_NOTE_CHAT_TEMPERATURE=0.7
AI_DEFAULT_STRUCTURE_TEMPERATURE=0.2
AI_DEFAULT_SUMMARY_TEMPERATURE=0.5

GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_STRUCTURE_MODEL=gemini-2.5-flash
GEMINI_SUMMARY_MODEL=gemini-2.5-flash
GEMINI_TRANSCRIPTION_MODEL=gemini-2.5-flash
GEMINI_GLOBAL_CHAT_MODEL=gemini-2.5-flash
GEMINI_NOTE_CHAT_MODEL=gemini-2.5-flash

MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_STRUCTURE_MODEL=mistral-small-latest
MISTRAL_SUMMARY_MODEL=mistral-small-latest
MISTRAL_TRANSCRIPTION_MODEL=voxtral-mini-latest
MISTRAL_GLOBAL_CHAT_MODEL=mistral-small-latest
MISTRAL_NOTE_CHAT_MODEL=mistral-small-latest

OLLAMA_LOCAL_BASE_URL=http://ollama:11434
OLLAMA_LOCAL_STRUCTURE_MODEL=qwen2.5:0.5b
OLLAMA_LOCAL_SUMMARY_MODEL=qwen2.5:0.5b
OLLAMA_LOCAL_GLOBAL_CHAT_MODEL=qwen2.5:0.5b
OLLAMA_LOCAL_NOTE_CHAT_MODEL=qwen2.5:0.5b

VOSK_LOCAL_MODELS_PATH=/app/models/vosk
VOSK_LOCAL_MODELS_HOST_PATH=./NeuroNotes.Infrastructure/Resources/Models/Vosk
VOSK_LOCAL_MODEL_RU=vosk-model-small-ru-0.22
VOSK_LOCAL_MODEL_EN=vosk-model-en-us-0.22-lgraph

# ==========================================
# === Hangfire Configuration ===
# ==========================================
HANGFIRE_USER=hangfire-user
HANGFIRE_PASSWORD=hangfire-password

# ==========================================
# === Embedding Configuration ===
# ==========================================
EMBEDDING_DEFAULT_PROVIDER=GemmaLocal
EMBEDDING_BASE_URL=http://ollama:11434
EMBEDDING_MODEL=embeddinggemma
EMBEDDING_DIMENSIONS=768
EMBEDDING_MAX_COSINE_DISTANCE=0.8
EMBEDDING_SEARCH_RESULT_LIMIT=5

# ==========================================
# === Category Classifier Configuration ===
# ==========================================
CATEGORY_CLASSIFIER_HOST_PATH=/app/models/category
CATEGORY_CLASSIFIER_CONTAINER_PATH=/app/models/category
CATEGORY_CLASSIFIER_MODEL_PATH=/app/models/category/neurone_bert.onnx
CATEGORY_CLASSIFIER_VOCAB_PATH=/app/models/category/vocab.txt
CATEGORY_CLASSIFIER_MIN_CONFIDENCE=0.5
CATEGORY_CLASSIFIER_MAX_SEQ_LENGTH=128